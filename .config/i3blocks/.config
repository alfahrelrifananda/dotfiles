[wireless]
command=iwgetid -r | sed 's/^/  /' || echo "󰖪 down"
interval=5

[ethernet]
command=ip addr show | grep "inet " | grep -v "127.0.0.1" | awk '{print "󰈁 " $2}' | head -1
interval=5

[battery]
command=cat /sys/class/power_supply/BAT0/capacity | sed 's/^/ /'
interval=30

[memory]
command=echo "󰍛 $(free -h | awk '/^Mem/ {print $3}')"
interval=5

[volume]
command=echo "  $(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\d+%' | head -1)"
interval=1

[brightness]
command=echo "󰃟 $(brightnessctl get)%"
interval=1

[time]
command=date "+%d %B %Y • %H:%M"
interval=1
